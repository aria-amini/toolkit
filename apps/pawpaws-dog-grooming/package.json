	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite dev",
		"preview": "vite preview",
		"start": "node .output/server/index.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --type-aware --max-warnings=0",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:update": "vitest run --project browser tests --update",
		"test:ui": "echo '\n  Vitest UI: http://127.0.0.1:51204/__vitest__/\n' && vitest --ui --open=false --api.host 0.0.0.0 --api.allowWrite true",
		"verify": "turbo run build test typecheck"
	},
	"dependencies": {
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@fontsource/playfair-display": "^5.2.8",
		"@fontsource/space-grotesk": "^5.2.8",
		"@tanstack/react-router": "^1.166.7",
		"@tanstack/react-start": "^1.166.7",
		"@tanstack/router-plugin": "^1.166.7",
		"lucide-react": "^1.8.0",
		"nitro": "latest",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@aamini/config-testing": "workspace:*",
		"@aamini/config-typescript": "workspace:*",
		"@aamini/config-vite": "workspace:*",
		"@tailwindcss/vite": "^4.2.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.4",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/ui": "^4.1.4",
		"msw": "^2.13.4",
		"playwright": "^1.59.1",
		"tailwindcss": "^4.2.1",
		"typescript": "6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"vitest-browser-react": "^2.2.0"
	}
