{
	"name": "portfolio",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite dev",
		"preview": "vite preview",
		"start": "node .output/server/index.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --type-aware --max-warnings=0",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project browser --project server",
		"test:update": "vitest run --project browser tests --update",
		"test:watch": "vitest --watch",
		"test:ui": "echo '\n  Vitest UI: http://127.0.0.1:51204/__vitest__/\n' && vitest --ui --open=false --api.host 0.0.0.0 --api.allowWrite true",
		"verify": "turbo run build test typecheck"
	},
	"dependencies": {
		"@aamini/lib": "workspace:*",
		"@aamini/ui": "workspace:@aamini/ui-neobrutalist@*",
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@hookform/resolvers": "^5.2.2",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-navigation-menu": "^1.2.14",
		"@radix-ui/react-slot": "^1.2.4",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.166.7",
		"@tanstack/react-router-devtools": "^1.166.7",
		"@tanstack/react-router-ssr-query": "^1.166.7",
		"@tanstack/react-start": "^1.166.7",
		"@tanstack/router-plugin": "^1.166.7",
		"arktype": "^2.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"form-data": "^4.0.5",
		"lucide-react": "^1.8.0",
		"mailgun.js": "^13.0.0",
		"nitro": "latest",
		"posthog-js": "^1.369.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.71.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@aamini/config-testing": "workspace:*",
