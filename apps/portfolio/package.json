		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.4",
		"@vitest/ui": "^4.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"dotenv": "^17.4.2",
		"msw": "^2.13.4",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "6.0.2",
		"vite": "^8.0.8",
