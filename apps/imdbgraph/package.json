{
	"name": "imdbgraph",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node .output/server/index.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --type-aware --max-warnings=0",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project browser --project server",
		"test:update": "vitest run --project browser tests --update",
		"test:watch": "vitest --watch",
		"test:ui": "echo '\n  Vitest UI: http://127.0.0.1:51204/__vitest__/\n' && vitest --ui --open=false --api.host 0.0.0.0 --api.allowWrite true",
		"e2e": "playwright test",
		"e2e:staging": "BASE_URL=https://imdbgraph.ariaamini.com playwright test",
		"e2e:update": "playwright test --update-snapshots",
		"report": "playwright show-report .playwright/report",
		"verify": "turbo run build test typecheck",
		"compose:dev": "docker compose up -d postgres && docker compose up app",
		"compose:infra": "docker compose up -d postgres",
		"compose:populate": "docker compose up populate",
		"compose:up": "docker compose up -d",
		"compose:logs": "docker compose logs -f app",
		"compose:down": "docker compose down",
		"populate": "tsx --env-file .env.local scripts/populate-db.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:check": "drizzle-kit check",
		"db:drop": "drizzle-kit drop"
	},
	"dependencies": {
		"@aamini/lib": "workspace:*",
		"@aamini/ui": "workspace:*",
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@tanstack/react-devtools": "^0.10.2",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.166.7",
		"@tanstack/react-router-devtools": "^1.166.7",
		"@tanstack/react-router-ssr-query": "^1.166.7",
		"@tanstack/react-start": "^1.166.7",
		"@tanstack/router-plugin": "^1.166.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"lucide-react": "^1.8.0",
		"nitro": "latest",
		"posthog-js": "^1.369.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"recharts": "2.15.4",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@aamini/config-testing": "workspace:*",
		"@aamini/config-typescript": "workspace:*",
		"@aamini/config-vite": "workspace:*",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/devtools-vite": "^0.6.0",
		"@testcontainers/postgresql": "^11.12.0",
		"@types/node": "^25.4.0",
		"@types/pg": "^8.18.0",
		"@types/pg-copy-streams": "^1.2.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vercel/functions": "^3.4.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.4",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/ui": "^4.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"drizzle-seed": "^0.3.1",
		"msw": "^2.13.4",
		"pg": "^8.20.0",
		"pg-copy-streams": "^7.0.0",
		"tailwindcss": "^4.2.1",
		"testcontainers": "^11.12.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"vitest-browser-react": "^2.0.5",
		"web-vitals": "^5.1.0",
		"zod": "^4.3.6"
	}
}
